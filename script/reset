#!/usr/bin/env bash
# script/reset
# Wipe the stored Playground site cache and start fresh from the blueprint.
# Note: your notes in ./data are NOT deleted by this script.
set -euo pipefail

cd "$(dirname "$0")/.."

if [ ! -d node_modules ]; then
  echo "==> Dependencies not installed. Running setup first..."
  ./script/setup
fi

# shellcheck source=/dev/null
source "$(dirname "$0")/lib/profile"

echo "==> Resetting WordPress Playground (site cache will be deleted; ./$DATA_DIR is untouched)."
[ "$PROFILE_LABEL" = "default" ] || echo "    Profile: $PROFILE_LABEL"
echo "    Press Ctrl+C within 5 seconds to cancel."
sleep 5

rm -rf "$SITE_DIR"

_BPTMP="$(mktemp /tmp/blueprint-XXXXXX)"
BLUEPRINT="${_BPTMP}.json"
trap 'rm -f "$_BPTMP" "$BLUEPRINT"' EXIT
node script/merge-blueprints > "$BLUEPRINT"

PORT="$(_find_free_port 9400)"

exec ./node_modules/.bin/wp-playground-cli start \
  --blueprint="$BLUEPRINT" \
  --port="$PORT" \
  --login
