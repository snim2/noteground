#!/usr/bin/env bash
# script/save
# Commit and push the private data repo. The database and uploads are mounted
# directly from the data repo so no copying is needed.
set -euo pipefail

cd "$(dirname "$0")/.."

# shellcheck source=/dev/null
source "$(dirname "$0")/lib/profile"

if [ ! -d "$DATA_DIR/.git" ]; then
  echo "Error: ./$DATA_DIR/ is not a git repository."
  if [ "$PROFILE_LABEL" = "default" ]; then
    echo "Run ./script/init-data <private-repo-url> first."
  else
    echo "Run NOTES_PROFILE=$PROFILE_LABEL ./script/init-data <private-repo-url> first."
  fi
  exit 1
fi

if [ ! -f "$DATA_DIR/database/.ht.sqlite" ]; then
  echo "Error: no database found at ./$DATA_DIR/database/.ht.sqlite"
  echo "Start WordPress at least once with ./script/start before saving."
  exit 1
fi

TIMESTAMP="$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
echo "==> Saving snapshot: $TIMESTAMP"

cd "$DATA_DIR"
git add database/ uploads/
git diff --cached --quiet && echo "    No changes to save." && exit 0
git commit -m "notes: $TIMESTAMP"
git push

echo ""
echo "==> Saved and pushed to your private notes repo."
