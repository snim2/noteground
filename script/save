#!/usr/bin/env bash
# script/save
# Copy the current database and media library out of the WP Playground site
# cache into the private data repo, then commit and push.
set -euo pipefail

cd "$(dirname "$0")/.."

# shellcheck source=/dev/null
source "$(dirname "$0")/lib/profile"

if [ ! -d "$DATA_DIR/.git" ]; then
  echo "Error: ./$DATA_DIR/ is not a git repository."
  if [ "$PROFILE_LABEL" = "default" ]; then
    echo "Run ./script/init-data <private-repo-url> first."
  else
    echo "Run NOTES_PROFILE=$PROFILE_LABEL ./script/init-data <private-repo-url> first."
  fi
  exit 1
fi

DB_FILE="$SITE_DIR/wp-content/database/.ht.sqlite"
UPLOADS_DIR="$SITE_DIR/wp-content/uploads"

if [ ! -f "$DB_FILE" ]; then
  echo "Error: no database found at $DB_FILE"
  echo "Start WordPress at least once with ./script/start before saving."
  exit 1
fi

mkdir -p "$DATA_DIR/database" "$DATA_DIR/uploads"

echo "==> Copying database and uploads from site cache..."
cp "$DB_FILE" "$DATA_DIR/database/.ht.sqlite"
if [ -d "$UPLOADS_DIR" ] && [ -n "$(ls -A "$UPLOADS_DIR")" ]; then
  cp -r "$UPLOADS_DIR/." "$DATA_DIR/uploads/"
fi

TIMESTAMP="$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
echo "==> Saving snapshot: $TIMESTAMP"

cd "$DATA_DIR"
git add database/ uploads/
git diff --cached --quiet && echo "    No changes to save." && exit 0
git commit -m "notes: $TIMESTAMP"
git push

echo ""
echo "==> Saved and pushed to your private notes repo."
