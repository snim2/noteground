#!/usr/bin/env bash
# script/setup
# Install all dependencies needed to run this project.
set -euo pipefail

cd "$(dirname "$0")/.."

echo "==> Installing Node.js dependencies..."
npm install

echo ""

# Initialise the data submodule if it has been configured but not yet cloned.
if [ -f .gitmodules ] && grep -q 'path = data' .gitmodules; then
  echo "==> Initialising data submodule..."
  git submodule update --init --recursive data
else
  echo "    No data submodule configured."
  echo "    Run ./script/init-data <private-repo-url> to set one up."
fi

echo ""
echo "==> Setup complete. Run ./script/start to launch WordPress."
