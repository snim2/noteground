#!/usr/bin/env bash
# script/setup
# Install all dependencies needed to run this project.
set -euo pipefail

cd "$(dirname "$0")/.."

echo "==> Installing Node.js dependencies..."
npm install

echo ""

if [ -d data/.git ]; then
  echo "    ./data/ is already set up."
else
  echo "    No data repo found at ./data/"
  echo "    Run ./script/init-data <private-repo-url> to set one up."
fi

echo ""
echo "==> Setup complete. Run ./script/start to launch WordPress."
