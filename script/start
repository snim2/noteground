#!/usr/bin/env bash
# script/start
# Start the local WordPress Playground development server.
set -euo pipefail
shopt -s nullglob dotglob

cd "$(dirname "$0")/.."

if [ ! -d node_modules ]; then
  echo "==> Dependencies not installed. Running setup first..."
  ./script/setup
fi

# shellcheck source=/dev/null
source "$(dirname "$0")/lib/profile"

mkdir -p "$DATA_DIR/database" "$DATA_DIR/uploads" "$DATA_DIR/plugins" "$DATA_DIR/themes"

DB_DIR="$SITE_DIR/wp-content/database"
UPLOADS_DIR="$SITE_DIR/wp-content/uploads"

[ "$PROFILE_LABEL" = "default" ] || echo "==> Profile: $PROFILE_LABEL (data dir: ./$DATA_DIR)"

# Only restore saved data if the site is already fully initialized.
# Seeding into a partial site directory causes WP Playground to fail during blueprint execution.
if [ -f "$SITE_DIR/wp-config.php" ]; then
  if [ -f "$DATA_DIR/database/.ht.sqlite" ]; then
    cp "$DATA_DIR/database/.ht.sqlite" "$DB_DIR/.ht.sqlite"
    echo "==> Restored database from ./$DATA_DIR/database"
  fi
  UPLOAD_FILES=("$DATA_DIR/uploads/"*)
  HAS_REAL_UPLOADS=false
  for f in "${UPLOAD_FILES[@]}"; do
    [[ "$(basename "$f")" == ".gitkeep" ]] && continue
    HAS_REAL_UPLOADS=true
    break
  done
  if $HAS_REAL_UPLOADS; then
    mkdir -p "$UPLOADS_DIR"
    cp -r "$DATA_DIR/uploads/." "$UPLOADS_DIR/"
    echo "==> Restored uploads from ./$DATA_DIR/uploads"
  fi
else
  echo "    Site not yet initialized — starting fresh."
  if [ -f "$DATA_DIR/database/.ht.sqlite" ]; then
    echo "    Your saved notes will be restored on the next start."
  fi
fi

_BPTMP="$(mktemp /tmp/blueprint-XXXXXX)"
BLUEPRINT="${_BPTMP}.json"

_playground_pid=""

_cleanup() {
  rm -f "$_BPTMP" "$BLUEPRINT"
  if [ -n "$_playground_pid" ] && kill -0 "$_playground_pid" 2>/dev/null; then
    kill "$_playground_pid" 2>/dev/null
    wait "$_playground_pid" 2>/dev/null || true
  fi
}

_on_interrupt() {
  echo ""
  read -r -p "==> Save site data before exit? [Y/n] " _answer
  case "$_answer" in
    [nN]*) ;;
    *) NOTES_PROFILE="$NOTES_PROFILE" ./script/save ;;
  esac
  _cleanup
  exit 0
}

trap '_cleanup' EXIT
trap '_on_interrupt' INT
node script/merge-blueprints > "$BLUEPRINT"
if [ -f blueprint-local.json ]; then
  echo "==> Merged blueprint.json + blueprint-local.json"
  echo "==> Validating merged blueprint JSON against schema..."
  check-jsonschema --schemafile schemas/blueprint.json "$BLUEPRINT"
fi

PORT="$(_find_free_port 9400)"

echo "==> Starting WordPress Playground..."
echo "    Admin URL: http://127.0.0.1:$PORT/wp-admin"
echo "    Credentials: admin / password"
echo "    Press Ctrl+C to stop."
echo ""

MOUNT_ARGS=()
for plugin_dir in "$DATA_DIR/plugins/"/*/; do
  [ -d "$plugin_dir" ] || continue
  name="$(basename "$plugin_dir")"
  MOUNT_ARGS+=(--mount "$(pwd)/$plugin_dir:/wordpress/wp-content/plugins/$name")
  echo "==> Mounting custom plugin: $name"
done
for theme_dir in "$DATA_DIR/themes/"/*/; do
  [ -d "$theme_dir" ] || continue
  name="$(basename "$theme_dir")"
  MOUNT_ARGS+=(--mount "$(pwd)/$theme_dir:/wordpress/wp-content/themes/$name")
  echo "==> Mounting custom theme: $name"
done

./node_modules/.bin/wp-playground-cli start \
  --blueprint="$BLUEPRINT" \
  --port="$PORT" \
  --login \
  "${MOUNT_ARGS[@]}" &
_playground_pid=$!
wait "$_playground_pid"
