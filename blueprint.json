{
  "$schema": "https://playground.wordpress.net/blueprint-schema.json",
  "preferredVersions": {
    "php": "8.4",
    "wp": "latest"
  },
  "meta": {
    "title": "Personal notes",
    "description": "Use WordPress as a personal notes store - a local-only app with site data saved to a Git repository.",
    "author": "snim2",
    "categories": [
      "Notes",
      "Productivity"
    ]
  },
  "login": true,
  "plugins": [
    "code-syntax-block"
  ],
  "landingPage": "/",
  "steps": [
    {
      "step": "setSiteOptions",
      "options": {
        "blogname": "Personal Notes",
        "blogdescription": "A personal knowledge base",
        "default_comment_status": "closed",
        "default_ping_status": "closed"
      }
    },
    {
      "step": "updateUserMeta",
      "meta": {
        "admin_color": "modern"
      },
      "userId": 1
    }
  ]
}
